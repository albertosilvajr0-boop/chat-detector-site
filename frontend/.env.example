# Copy to .env.local and fill in.
# VITE_ prefixed vars are exposed to the client bundle.

# Cloud Run URL of the backend API (from `gcloud run deploy` output).
VITE_API_BASE_URL=http://localhost:8080

# Firebase web app config — paste from Firebase Console > Project Settings > Web app.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
