{
  "hosting": {
    "target": "protest-helper",
    "public": "frontend/dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "/healthz",
        "run": {
          "serviceId": "protest-helper",
          "region": "us-central1"
        }
      },
      {
        "source": "/health",
        "run": {
          "serviceId": "protest-helper",
          "region": "us-central1"
        }
      },
      {
        "source": "/search",
        "run": {
          "serviceId": "protest-helper",
          "region": "us-central1"
        }
      },
      {
        "source": "/counties",
        "run": {
          "serviceId": "protest-helper",
          "region": "us-central1"
        }
      },
      {
        "source": "/analyze/**",
        "run": {
          "serviceId": "protest-helper",
          "region": "us-central1"
        }
      },
      {
        "source": "/packet/**",
        "run": {
          "serviceId": "protest-helper",
          "region": "us-central1"
        }
      },
      {
        "source": "/admin/protest-candidates.csv",
        "run": {
          "serviceId": "protest-helper",
          "region": "us-central1"
        }
      },
      { "source": "**", "destination": "/index.html" }
    ],
    "headers": [
      {
        "source": "**/*.@(js|css|svg|woff2)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
        ]
      },
      {
        "source": "/index.html",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache" }
        ]
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  }
}
