rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == 'albertosilva@silvaconsultinggroup.com';
    }

    function hasOptionalString(field, maxLength) {
      return !request.resource.data.keys().hasAny([field])
        || (request.resource.data[field] is string
          && request.resource.data[field].size() < maxLength);
    }

    function hasOptionalNumber(field) {
      return !request.resource.data.keys().hasAny([field])
        || request.resource.data[field] is number;
    }

    function hasOptionalBoolean(field) {
      return !request.resource.data.keys().hasAny([field])
        || request.resource.data[field] is bool;
    }

    // Public lead capture from the website.
    // Anyone can create a lead document; only the admin Firebase Auth user can read it.
    match /leads/{leadId} {
      allow create: if request.resource.data.keys().hasOnly(
                      ['email','county','countyLabel','propertyId','situsAddress','owner','appraisedValue',
                       'targetValue','estimatedReduction','estimatedSavings',
                       'isProtestable','requestType','reason',
                       'name','phone','ts','userAgent','referrer'])
                    && request.resource.data.email is string
                    && request.resource.data.email.size() < 200
                    && request.resource.data.email.matches('^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$')
                    && request.resource.data.county in ['bexar', 'arapahoe']
                    && hasOptionalString('countyLabel', 80)
                    && ((request.resource.data.propertyId is string
                        && request.resource.data.propertyId.size() < 80)
                      || request.resource.data.propertyId is number)
                    && hasOptionalString('situsAddress', 300)
                    && hasOptionalString('owner', 300)
                    && hasOptionalNumber('appraisedValue')
                    && hasOptionalNumber('targetValue')
                    && hasOptionalNumber('estimatedReduction')
                    && hasOptionalNumber('estimatedSavings')
                    && hasOptionalBoolean('isProtestable')
                    && (!request.resource.data.keys().hasAny(['requestType'])
                      || request.resource.data.requestType in ['packet', 'info'])
                    && hasOptionalString('reason', 120)
                    && hasOptionalString('name', 120)
                    && hasOptionalString('phone', 40)
                    && hasOptionalString('userAgent', 500)
                    && (!request.resource.data.keys().hasAny(['referrer'])
                      || request.resource.data.referrer == null
                      || (request.resource.data.referrer is string
                        && request.resource.data.referrer.size() < 500));
      allow read: if isAdmin();
      allow update, delete: if false;
    }
    // Everything else: locked down.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
